# ── Server ────────────────────────────────────────────────────────────────────
# Port the server listens on. Railway sets this automatically — do NOT set it manually there.
PORT=3000

# ── Host Authentication ────────────────────────────────────────────────────────
# 6-character alphanumeric code that protects the host/conductor view.
# If omitted, the server generates a random code on each startup and logs it to the console.
# Uncomment and set a fixed value in production so restarts don't change the code.
# HOST_CODE=RIZAL1

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the deployed frontend (Vercel). Restricts which origins can call the server.
# Leave blank for local dev (defaults to * — allows all origins).
CLIENT_URL=https://your-frontend.vercel.app

# ── QR Code / Join URL ────────────────────────────────────────────────────────
# URL shown in the host lobby QR code so remote players can join.
# Leave blank for local dev (defaults to http://<local-wifi-ip>:5173).
# In production, set this to your Vercel URL.
GAME_URL=https://your-frontend.vercel.app
